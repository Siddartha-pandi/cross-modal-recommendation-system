# Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Search Provider ──────────────────────────────────────────────────────────
# Options: "serpapi" (recommended) | "google" | "duckduckgo"
SEARCH_PROVIDER=serpapi

# ─── Google Custom Search API (optional fallback for /recommend) ─────────────
# Step-by-step setup:
#   1. Get API Key:
#      → https://console.cloud.google.com/apis/credentials
#      → Create Project → Enable "Custom Search API" → Create API Key
#   2. Get Search Engine ID (cx):
#      → https://programmablesearchengine.google.com/
#      → Create Search Engine → Sites to search: "myntra.com amazon.in flipkart.com ajio.com"
#      → Copy the "Search engine ID"

GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CX=your_custom_search_engine_id_here

# ─── SerpAPI (recommended primary) ───────────────────────────────────────────
# Required when SEARCH_PROVIDER=serpapi
SERP_API_KEY=your_serpapi_key_here

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/fashion_db

# ─── JWT Authentication ───────────────────────────────────────────────────────
# SECRET_KEY=your-secret-key-here
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── CLIP Models ─────────────────────────────────────────────────────────────
# CLIP_MODEL_LARGE=ViT-L/14    # Used for /recommend (live web search)
# CLIP_MODEL_SMALL=ViT-B/32   # Used for /search (FAISS index)

# ─── Search Settings ─────────────────────────────────────────────────────────
# TOP_K=10
# MAX_CANDIDATES=20
# IMAGE_ALPHA=0.6
# TEXT_BETA=0.4
